---
const { title = "Designer tip" } = Astro.props;
---
<aside class="tip">
  <p class="tip__label">💡 {title}</p>
  <slot />
</aside>
<style>
  .tip { border-left: 4px solid #CE422B; background: var(--sl-color-accent-low); color: var(--sl-color-accent-high); padding: 0.75rem 1rem; border-radius: 0 6px 6px 0; margin: 1rem 0; }
  .tip__label { font-weight: 700; margin: 0 0 .25rem; color: var(--sl-color-accent-high); }
</style>

---
const { title = "No TypeScript equivalent" } = Astro.props;
---
<aside class="rs-only">
  <p class="rs-only__label">🟦 {title}</p>
  <slot />
</aside>
<style>
  .rs-only { border-left: 4px solid #CE422B; background: var(--sl-color-accent-low); color: var(--sl-color-accent-high); padding: 0.75rem 1rem; border-radius: 0 6px 6px 0; margin: 1rem 0; }
  .rs-only__label { font-weight: 700; margin: 0 0 .25rem; color: var(--sl-color-accent-high); }
</style>
